{
  "name": "human-or-ai",
  "version": "1.0.0",
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "start:clean": "expo start --clear",
    "web": "expo start --web",
    "web:clean": "expo start --web --clear",
    "android": "expo start --android",
    "android:run": "bash scripts/start-android.sh",
    "ios": "expo start --ios",
    "test": "jest --passWithNoTests",
    "generate-assets": "python3 scripts/generate-assets.py",
    "prebuild:check": "npx tsc --noEmit && npm test",
    "eas:login": "eas login",
    "eas:whoami": "eas whoami",
    "eas:init": "eas init",
    "eas:bootstrap": "bash scripts/eas-bootstrap.sh",
    "build:android": "CI=false eas build --platform android --profile production",
    "build:playstore": "CI=false eas build --platform android --profile production",
    "build:android:apk": "CI=false eas build --platform android --profile preview",
    "build:android:setup": "CI=false eas credentials -p android",
    "build:android:apk:ci": "eas build --platform android --profile preview --non-interactive",
    "build:ios": "eas build --platform ios --profile production"
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.1",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "expo": "~52.0.0",
    "expo-asset": "~11.0.5",
    "expo-av": "~15.0.0",
    "expo-haptics": "~14.0.0",
    "expo-image": "~2.0.7",
    "expo-localization": "~16.0.1",
    "expo-notifications": "~0.29.14",
    "expo-sharing": "~13.0.0",
    "expo-status-bar": "~2.0.0",
    "i18next": "^25.8.18",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-i18next": "^16.5.8",
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.20.0",
    "react-native-reanimated": "~3.16.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "~0.19.13"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/jest": "^29.5.0",
    "@types/react": "~18.3.12",
    "eas-cli": "^16.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "~5.3.0"
  },
  "private": true
}
